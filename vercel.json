{
  "builds": [
    {
      "src": "lead-generator-ai-master/streamlit_app.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip install -r lead-generator-ai-master/requirements.txt",
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "lead-generator-ai-master/streamlit_app.py"
    }
  ]
}
